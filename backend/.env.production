# Variables de entorno para producción - Backend
# Copia este archivo a .env y configura los valores según tu entorno de producción

# Database - Configura con tu servidor PostgreSQL de producción
DATABASE_URL="postgresql://username:password@host:port/project_management?schema=public"

# Server
PORT=3001

# JWT Secret - Genera una clave segura para producción
JWT_SECRET="tu_clave_secreta_muy_segura_aqui"

# Environment
NODE_ENV=production