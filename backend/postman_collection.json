        { "name": "PUT /taskLogs/:id", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"comment\": \"Updated comment\"\n}" }, "url": { "raw": "{{baseUrl}}/taskLogs/:id" } } },
