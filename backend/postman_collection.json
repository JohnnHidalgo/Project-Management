{
  "info": {
    "name": "project-management-backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3002/api",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login" }
          }
        },
        {
          "name": "GET /auth/profile",
          "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/auth/profile" } }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        { "name": "GET /users", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/users" } } },
        { "name": "GET /users/:id", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/users/:id" } } },
        { "name": "POST /users", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Example\",\n  \"email\": \"user@example.com\",\n  \"password\": \"secret\",\n  \"role\": \"Team_Member\"\n}" }, "url": { "raw": "{{baseUrl}}/users" } } },
        { "name": "PUT /users/:id", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Updated\"\n}" }, "url": { "raw": "{{baseUrl}}/users/:id" } } },
        { "name": "DELETE /users/:id", "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/users/:id" } } }
      ]
    },
    {
      "name": "Projects",
      "item": [
        { "name": "GET /projects", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/projects" } } },
        { "name": "GET /projects/:id", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/projects/:id" } } },
        { "name": "POST /projects", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"New Project\",\n  \"description\": \"...\"\n}" }, "url": { "raw": "{{baseUrl}}/projects" } } },
        { "name": "PUT /projects/:id", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Updated Project\"\n}" }, "url": { "raw": "{{baseUrl}}/projects/:id" } } },
        { "name": "PUT /projects/:id/toggle-edit", "request": { "method": "PUT", "url": { "raw": "{{baseUrl}}/projects/:id/toggle-edit" } } },
        { "name": "DELETE /projects/:id", "request": { "method": "DELETE", "url": { "raw": "{{baseUrl}}/projects/:id" } } }
      ]
    },
